# FINFA configuration. setup.sh writes this file for you — you normally do not
# edit it by hand. Copy to ".env" and fill in only if setting up manually.
# NEVER commit .env (it is gitignored).
# ============================================================================

# ---- Marzban panel ----------------------------------------------------------
# Host port the panel is published on (loopback only — see docker-compose.yml).
PANEL_PORT=8000

# Panel bind INSIDE the container. Leave 0.0.0.0; the host publish maps it to
# 127.0.0.1 only, so it is never reachable off-box.
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# Sudo admin for the panel + API. Use a STRONG password (setup.sh generates one).
SUDO_USERNAME=admin
SUDO_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Database — SQLite inside the named volume (default). Nothing scattered on host.
SQLALCHEMY_DATABASE_URL=sqlite:////var/lib/marzban/db.sqlite3

# Xray base config — file-managed (config-as-code). Mounted read-only.
XRAY_JSON=/var/lib/marzban/xray_config.json

# ---- Concurrency watcher ----------------------------------------------------
# Max distinct source NETWORKS allowed per user within the window. Mobile/CGNAT
# users rotate their public IP on nearly every connection, so we count distinct
# /WATCH_IP_PREFIX networks, NOT individual IPs (else one phone looks like many
# devices). 5 suits home + mobile; raise it for heavier mobile use.
WATCH_IP_LIMIT=5
# Bucket size: distinct /24 (IPv4) networks ≈ "distinct places". If a single
# mobile carrier still spans too many /24s and trips users, lower it (e.g. 16).
WATCH_IP_PREFIX=24
# Sliding window for counting distinct networks (seconds).
WATCH_WINDOW_SECONDS=120
# How long a user stays disabled after tripping the cap (seconds).
WATCH_COOLDOWN_SECONDS=300
# Xray access log path inside the shared volume.
WATCH_ACCESS_LOG=/var/lib/marzban/access.log
# Marzban API reachable from the watcher container (compose service DNS name).
MARZBAN_BASE_URL=https://marzban:8000
MARZBAN_ADMIN_USERNAME=admin
MARZBAN_ADMIN_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_STRING
# Start in DRY-RUN: log violations but do NOT disable users. Flip to false to enforce.
WATCH_DRY_RUN=false

# ---- Telegram bot (optional; Marzban's built-in admin bot) ------------------
# Leave both blank to disable. Create a bot with @BotFather to get the token;
# get your numeric admin id from @userinfobot.
TELEGRAM_API_TOKEN=
TELEGRAM_ADMIN_ID=

# ---- Cloudflare CDN front (optional; defeats IP-blocking) -------------------
# Leave blank for the plain Reality-direct setup. To enable, run
# scripts/enable-cdn.sh (it fills these + the WS path + assigns users). See
# docs/cdn-cloudflare.md. The token is your tunnel's connector token.
CF_DOMAIN=
CF_TUNNEL_TOKEN=
# Pinned Cloudflare "clean IP(s)", comma-separated. Client links connect
# straight to these (no DNS lookup) so DNS poisoning can't touch them. Any
# reachable Cloudflare edge IP routes by SNI/Host; pick one(s) that aren't
# throttled from your users' region. Multiple = each user gets fallbacks.
# (ECH is pulled live from the domain's DNS at link-generation time, so the
# real SNI stays encrypted and links never go stale — nothing to set here.)
CF_CLEAN_IP=104.17.147.22,162.159.192.1
